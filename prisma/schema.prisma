generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  email              String?           @unique(map: "users_email_unique")
  username           String?           @unique(map: "users_username_unique")
  passwordHash       String?           @map("password_hash")
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  firstName          String?           @map("first_name")
  lastName           String?           @map("last_name")
  profileImageUrl    String?           @map("profile_image_url")
  bio                String?
  instagramHandle    String?           @unique @map("instagram_handle")
  isVerified         Boolean           @default(false) @map("is_verified")
  location           String?
  website            String?
  instagramId        String?           @unique @map("instagram_id")
  instagramPostCount Int               @default(0) @map("instagram_post_count")
  isInstagramImport  Boolean           @default(false) @map("is_instagram_import")
  lastInstagramSync  DateTime?         @map("last_instagram_sync") @db.Timestamp(6)
  activities         Activity[]
  conversations      Conversation[]
  following          Follow[]          @relation("follower")
  followers          Follow[]          @relation("following")
  instagramImports   InstagramImport[]
  lists              List[]
  photos             Photo[]
  reviews            Review[]
  savedPlaces        SavedPlace[]

  @@map("users")
}

model Session {
  sid    String   @id @db.VarChar
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
  @@map("session")
}

model Place {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  googlePlaceId    String       @unique(map: "places_google_place_id_unique") @map("google_place_id")
  name             String
  formattedAddress String       @map("formatted_address")
  neighborhood     String?
  locality         String?
  lat              Float        @db.Real
  lng              Float        @db.Real
  primaryType      String?      @map("primary_type")
  types            Json?
  priceLevel       String?      @map("price_level")
  photoRefs        Json?        @map("photo_refs")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  activities       Activity[]
  listPlaces       ListPlace[]
  photos           Photo[]
  reviews          Review[]
  savedPlaces      SavedPlace[]

  @@map("places")
}

model SavedPlace {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  userId    String    @map("user_id") @db.VarChar(36)
  placeId   String    @map("place_id") @db.VarChar(36)
  visitedAt DateTime? @map("visited_at") @db.Timestamp(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  hasBeen   Boolean?  @default(false) @map("has_been")
  rating    Int?
  emoji     String?
  place     Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
  @@map("saved_places")
}

model List {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  userId      String          @map("user_id") @db.VarChar(36)
  name        String
  description String?
  visibility  list_visibility @default(PRIVATE)
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  isSystem    Boolean?        @default(false) @map("is_system")
  systemSlug  String?         @map("system_slug") @db.VarChar(255)
  activities  Activity[]
  listPlaces  ListPlace[]
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("lists")
}

model ListPlace {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  listId    String   @map("list_id") @db.VarChar(36)
  placeId   String   @map("place_id") @db.VarChar(36)
  addedAt   DateTime @default(now()) @map("added_at") @db.Timestamp(6)
  note      String?
  sortOrder Int?     @map("sort_order")
  list      List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([listId, placeId])
  @@map("list_places")
}

model Follow {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  followerId  String   @map("follower_id") @db.VarChar(36)
  followingId String   @map("following_id") @db.VarChar(36)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model Activity {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  actorId   String        @map("actor_id") @db.VarChar(36)
  type      activity_type
  placeId   String?       @map("place_id") @db.VarChar(36)
  listId    String?       @map("list_id") @db.VarChar(36)
  metadata  Json?
  dedupeKey String        @unique @map("dedupe_key")
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  actor     User          @relation(fields: [actorId], references: [id], onDelete: Cascade)
  list      List?         @relation(fields: [listId], references: [id])
  place     Place?        @relation(fields: [placeId], references: [id])

  @@index([actorId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("activities")
}

model Review {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  userId             String        @map("user_id") @db.VarChar(36)
  placeId            String        @map("place_id") @db.VarChar(36)
  rating             Int?
  note               String?
  visitedAt          DateTime?     @map("visited_at") @db.Timestamp(6)
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  instagramEmbedHtml String?       @map("instagram_embed_html")
  instagramPostId    String?       @unique @map("instagram_post_id")
  instagramShortcode String?       @map("instagram_shortcode")
  instagramUrl       String?       @map("instagram_url")
  source             review_source @default(manual)
  
  // Social post content (for rendering preview without API calls)
  socialPostAuthor      String?    @map("social_post_author")
  socialPostAuthorImage String?    @map("social_post_author_image")
  socialPostCaption     String?    @map("social_post_caption")
  socialPostMediaUrl    String?    @map("social_post_media_url")
  socialPostMediaType   String?    @map("social_post_media_type") // image, video, carousel
  socialPostLikes       Int?       @map("social_post_likes")
  socialPostPostedAt    DateTime?  @map("social_post_posted_at") @db.Timestamp(6)
  
  photos             Photo[]
  place              Place         @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([placeId])
  @@index([instagramPostId])
  @@index([source])
  @@map("reviews")
}

model Photo {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  userId           String   @map("user_id") @db.VarChar(36)
  placeId          String   @map("place_id") @db.VarChar(36)
  reviewId         String?  @map("review_id") @db.VarChar(36)
  url              String
  width            Int?
  height           Int?
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  carouselPosition Int      @default(0) @map("carousel_position")
  isCarousel       Boolean  @default(false) @map("is_carousel")
  place            Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  review           Review?  @relation(fields: [reviewId], references: [id])
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([placeId, createdAt(sort: Desc)])
  @@index([reviewId, carouselPosition])
  @@map("photos")
}

model InstagramImport {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  instagramPostId    String        @unique @map("instagram_post_id")
  instagramUrl       String        @map("instagram_url")
  instagramShortcode String        @map("instagram_shortcode")
  userId             String?       @map("user_id") @db.VarChar(36)
  placeId            String?       @map("place_id") @db.VarChar(36)
  reviewId           String?       @map("review_id") @db.VarChar(36)
  status             import_status @default(pending)
  errorMessage       String?       @map("error_message")
  importedBy         String        @map("imported_by") @db.VarChar(36)
  rawData            Json?         @map("raw_data")
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  importedByUser     User          @relation(fields: [importedBy], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([importedBy])
  @@map("instagram_imports")
}

enum list_visibility {
  PRIVATE
  PUBLIC
}

enum activity_type {
  PLACE_SAVED
  PLACE_MARKED_BEEN
  PLACE_ADDED_TO_LIST
  LIST_CREATED
  REVIEW_CREATED
}

enum review_source {
  manual
  instagram
  tiktok
}

enum import_status {
  pending
  processing
  completed
  failed
}

model Conversation {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  userId    String    @map("user_id") @db.VarChar(36)
  title     String    @default("New Chat")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  messages  ChatMessage[]
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("conversations")
}

model ChatMessage {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  conversationId String       @map("conversation_id") @db.VarChar(36)
  role           String
  content        String
  places         Json?
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("chat_messages")
}
