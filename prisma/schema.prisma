generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  email              String?           @unique(map: "users_email_unique")
  username           String?           @unique(map: "users_username_unique")
  passwordHash       String?           @map("password_hash")
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  firstName          String?           @map("first_name")
  lastName           String?           @map("last_name")
  profileImageUrl    String?           @map("profile_image_url")
  bio                String?
  instagramHandle    String?           @unique @map("instagram_handle")
  isVerified         Boolean           @default(false) @map("is_verified")
  location           String?
  website            String?
  avatarEmoji        String?           @map("avatar_emoji")
  instagramId        String?           @unique @map("instagram_id")
  instagramPostCount Int               @default(0) @map("instagram_post_count")
  isInstagramImport  Boolean           @default(false) @map("is_instagram_import")
  lastInstagramSync  DateTime?         @map("last_instagram_sync") @db.Timestamp(6)
  activities         Activity[]
  conversations      Conversation[]
  following          Follow[]          @relation("follower")
  followers          Follow[]          @relation("following")
  lists              List[]
  photos             Photo[]
  reviews            Review[]
  savedPlaces        SavedPlace[]

  @@map("users")
}

model Session {
  sid    String   @id @db.VarChar
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
  @@map("session")
}

model Place {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  googlePlaceId    String             @unique(map: "places_google_place_id_unique") @map("google_place_id")
  name             String
  formattedAddress String             @map("formatted_address")
  neighborhood     String?
  locality         String?
  lat              Float              @db.Real
  lng              Float              @db.Real
  primaryType      String?            @map("primary_type")
  types            Json?
  priceLevel       String?            @map("price_level")
  photoRefs        Json?              @map("photo_refs")
  aiSummary        String?            @map("ai_summary")
  aiSummaryUpdatedAt DateTime?        @map("ai_summary_updated_at") @db.Timestamp(6)
  topChips         Json?              @map("top_chips")
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  activities       Activity[]
  listPlaces       ListPlace[]
  photos           Photo[]
  placeTags        PlaceTag[]
  placeTagAggregates PlaceTagAggregate[]
  reviews          Review[]
  savedPlaces      SavedPlace[]

  @@map("places")
}

model SavedPlace {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  userId    String    @map("user_id") @db.VarChar(36)
  placeId   String    @map("place_id") @db.VarChar(36)
  visitedAt DateTime? @map("visited_at") @db.Timestamp(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  hasBeen   Boolean?  @default(false) @map("has_been")
  rating    Int?
  emoji     String?
  place     Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
  @@map("saved_places")
}

model List {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  userId      String          @map("user_id") @db.VarChar(36)
  name        String
  description String?
  visibility  list_visibility @default(PRIVATE)
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  isSystem    Boolean?        @default(false) @map("is_system")
  systemSlug  String?         @map("system_slug") @db.VarChar(255)
  activities  Activity[]
  listPlaces  ListPlace[]
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("lists")
}

model ListPlace {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  listId    String   @map("list_id") @db.VarChar(36)
  placeId   String   @map("place_id") @db.VarChar(36)
  addedAt   DateTime @default(now()) @map("added_at") @db.Timestamp(6)
  note      String?
  sortOrder Int?     @map("sort_order")
  list      List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([listId, placeId])
  @@map("list_places")
}

model Follow {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  followerId  String   @map("follower_id") @db.VarChar(36)
  followingId String   @map("following_id") @db.VarChar(36)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model Activity {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  actorId   String        @map("actor_id") @db.VarChar(36)
  type      activity_type
  placeId   String?       @map("place_id") @db.VarChar(36)
  listId    String?       @map("list_id") @db.VarChar(36)
  metadata  Json?
  dedupeKey String        @unique @map("dedupe_key")
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  actor     User          @relation(fields: [actorId], references: [id], onDelete: Cascade)
  list      List?         @relation(fields: [listId], references: [id])
  place     Place?        @relation(fields: [placeId], references: [id])

  @@index([actorId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("activities")
}

model Review {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  userId             String        @map("user_id") @db.VarChar(36)
  placeId            String        @map("place_id") @db.VarChar(36)
  rating             Int?
  note               String?
  visitedAt          DateTime?     @map("visited_at") @db.Timestamp(6)
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  instagramEmbedHtml String?       @map("instagram_embed_html")
  instagramPostId    String?       @unique @map("instagram_post_id")
  instagramShortcode String?       @map("instagram_shortcode")
  instagramUrl       String?       @map("instagram_url")
  source             review_source @default(manual)
  socialPostCaption     String?    @map("social_post_caption")
  socialPostMediaUrl    String?    @map("social_post_media_url")
  socialPostMediaType   String?    @map("social_post_media_type")
  socialPostLikes       Int?       @map("social_post_likes")
  socialPostPostedAt    DateTime?  @map("social_post_posted_at") @db.Timestamp(6)
  photos             Photo[]
  reviewTags         ReviewTag[]
  ingestedPosts      IngestedPost[]
  place              Place         @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([placeId])
  @@index([instagramPostId])
  @@index([source])
  @@map("reviews")
}

model Photo {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  userId           String   @map("user_id") @db.VarChar(36)
  placeId          String   @map("place_id") @db.VarChar(36)
  reviewId         String?  @map("review_id") @db.VarChar(36)
  url              String
  width            Int?
  height           Int?
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  carouselPosition Int      @default(0) @map("carousel_position")
  isCarousel       Boolean  @default(false) @map("is_carousel")
  place            Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  review           Review?  @relation(fields: [reviewId], references: [id])
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([placeId, createdAt(sort: Desc)])
  @@index([reviewId, carouselPosition])
  @@map("photos")
}

model ImportJob {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  platform        import_platform
  type            import_type
  input           String
  maxPosts        Int             @default(100) @map("max_posts")
  status          job_status      @default(pending)
  postsFetched    Int             @default(0) @map("posts_fetched")
  postsProcessed  Int             @default(0) @map("posts_processed")
  reviewsCreated  Int             @default(0) @map("reviews_created")
  postsUnresolved Int             @default(0) @map("posts_unresolved")
  postsFailed     Int             @default(0) @map("posts_failed")
  error           String?
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  startedAt       DateTime?       @map("started_at") @db.Timestamp(6)
  completedAt     DateTime?       @map("completed_at") @db.Timestamp(6)
  ingestedPosts   IngestedPost[]

  @@index([platform, status, createdAt])
  @@map("import_jobs")
}

model IngestedPost {
  id                   String          @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  platform             import_platform
  importJobId          String          @map("import_job_id") @db.VarChar(36)
  canonicalPostId      String          @map("canonical_post_id")
  url                  String
  authorHandle         String          @map("author_handle")
  authorPlatformId     String?         @map("author_platform_id")
  caption              String?
  postedAt             DateTime?       @map("posted_at") @db.Timestamp(6)
  likeCount            Int?            @map("like_count")
  media                Json?
  rawPayload           Json?           @map("raw_payload")
  resolvedGooglePlaceId String?        @map("resolved_google_place_id")
  resolveMethod        resolve_method? @map("resolve_method")
  resolveConfidence    Float?          @map("resolve_confidence")
  resolveCandidates    Json?           @map("resolve_candidates")
  reviewId             String?         @map("review_id") @db.VarChar(36)
  status               post_status     @default(new)
  error                String?
  createdAt            DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt            DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  importJob            ImportJob       @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  review               Review?         @relation(fields: [reviewId], references: [id])

  @@unique([platform, canonicalPostId])
  @@index([status])
  @@index([authorHandle])
  @@index([resolvedGooglePlaceId])
  @@map("ingested_posts")
}

model Job {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  type      job_type
  payload   Json
  status    job_status @default(queued)
  attempts  Int        @default(0)
  runAfter  DateTime   @default(now()) @map("run_after") @db.Timestamp(6)
  error     String?
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@index([status, runAfter])
  @@index([type, status])
  @@map("jobs")
}

model ReviewTag {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  reviewId   String     @map("review_id") @db.VarChar(36)
  tagId      String     @map("tag_id") @db.VarChar(36)
  source     tag_source @default(ai)
  confidence Float
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  review     Review     @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  tag        Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([reviewId, tagId])
  @@index([reviewId])
  @@index([tagId])
  @@map("review_tags")
}

model PlaceTagAggregate {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  placeId         String   @map("place_id") @db.VarChar(36)
  tagId           String   @map("tag_id") @db.VarChar(36)
  confidence      Float
  evidenceCount   Int      @default(0) @map("evidence_count")
  evidenceScore   Float    @default(0) @map("evidence_score")
  lastComputedAt  DateTime @default(now()) @map("last_computed_at") @db.Timestamp(6)
  isSuppressed    Boolean  @default(false) @map("is_suppressed")
  sourceBreakdown Json?    @map("source_breakdown")
  place           Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  tag             Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([placeId, tagId])
  @@index([placeId, confidence])
  @@map("place_tag_aggregates")
}

model Conversation {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  userId    String    @map("user_id") @db.VarChar(36)
  title     String    @default("New Chat")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  messages  ChatMessage[]
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("conversations")
}

model ChatMessage {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  conversationId String       @map("conversation_id") @db.VarChar(36)
  role           String
  content        String
  places         Json?
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("chat_messages")
}

model TagCategory {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  slug         String  @unique
  displayName  String  @map("display_name")
  description  String?
  searchWeight Float   @default(1.0) @map("search_weight")
  sortOrder    Int     @default(0) @map("sort_order")
  iconName     String? @map("icon_name")
  tags         Tag[]

  @@map("tag_categories")
}

model Tag {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  categoryId        String              @map("category_id") @db.VarChar(36)
  slug              String              @unique
  displayName       String              @map("display_name")
  description       String?
  iconName          String?             @map("icon_name")
  sortOrder         Int                 @default(0) @map("sort_order")
  category          TagCategory         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  placeTags         PlaceTag[]
  reviewTags        ReviewTag[]
  placeTagAggregates PlaceTagAggregate[]

  @@index([categoryId])
  @@map("tags")
}

model PlaceTag {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  placeId    String     @map("place_id") @db.VarChar(36)
  tagId      String     @map("tag_id") @db.VarChar(36)
  source     tag_source @default(manual)
  confidence Float?
  addedById  String?    @map("added_by_id") @db.VarChar(36)
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  place      Place      @relation(fields: [placeId], references: [id], onDelete: Cascade)
  tag        Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([placeId, tagId])
  @@index([placeId])
  @@index([tagId])
  @@map("place_tags")
}

enum list_visibility {
  PRIVATE
  PUBLIC
}

enum activity_type {
  PLACE_SAVED
  PLACE_MARKED_BEEN
  PLACE_ADDED_TO_LIST
  LIST_CREATED
  REVIEW_CREATED
}

enum review_source {
  manual
  instagram
  tiktok
}

enum import_platform {
  instagram
  tiktok
}

enum import_type {
  profile
  post_url
  place_seed
}

enum job_status {
  pending
  queued
  running
  completed
  failed
  cancelled
}

enum post_status {
  new
  processed
  unresolved
  failed
}

enum resolve_method {
  geotag
  caption
  hashtag
  ai
  manual
  none
}

enum job_type {
  IMPORT_PROFILE
  PROCESS_POST
  ENRICH_REVIEW
  UPDATE_PLACE_AGGREGATES
  REFRESH_PLACE_SUMMARY
}

enum tag_source {
  manual
  ai
  google
  user
}

enum import_status {
  pending
  processing
  completed
  failed
}
